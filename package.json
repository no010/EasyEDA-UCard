		"url": "https://github.com/no010/EasyEDA-UCard"
	},
	"bugs": {
		"url": "https://github.com/no010/EasyEDA-UCard/issues"
	},
	"engines": {
		"node": ">=20.17.0"
	},
	"scripts": {
		"compile": "rimraf ./dist/ && ts-node ./config/esbuild.prod.ts",
